# Telegram Bot configuration
TELEGRAM_BOT_TOKEN=your_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Web search API (https://tavily.com — free tier available)
TAVILY_API_KEY=your_tavily_key_here

# Triage filter — Groq API (https://console.groq.com — free tier available)
GROQ_API_KEY=your_groq_key_here

# Ollama runs locally — no API key required.
# Change these only if Ollama is on a non-default host/port or you want a different model.
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=deepseek-r1:7b
